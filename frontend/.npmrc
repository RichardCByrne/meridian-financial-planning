# Pin the public npm registry explicitly. Without this, Dependabot infers a
# private registry (npm.pkg.github.com) for scoped packages (@tanstack/@types/
# @vitejs) and aborts the update/merge with "can't access a private package
# registry without explicit configuration". We publish/consume nothing from
# GitHub Packages — everything resolves from npmjs.
registry=https://registry.npmjs.org/

# Supply-chain cooldown: refuse versions published in the last N days.
# Blocks newly-uploaded compromised releases before disclosure. See
# DEPLOY.md Appendix B.6. Requires npm >=11.10.0.
min-release-age=7
