# Meridian backend env vars.
# Copy to `.env` (gitignored) and adjust for your environment.
# `app/db.py` and `app/main.py` read these directly via os.environ.

# Database connection string.
# Local dev (default): leave unset → SQLite at backend/meridian.db.
# Production: postgresql+psycopg://USER:PASSWORD@/DATABASE?host=/cloudsql/PROJECT:REGION:INSTANCE
# DATABASE_URL=

# Auth mode. When `true` (default), Firebase verification is bypassed and the
# seeded "Local Dev User" is returned for every request.
MERIDIAN_DEV_AUTH=true

# Required when MERIDIAN_DEV_AUTH=false. Path to a Firebase service-account
# JSON. In Cloud Run this is mounted from Secret Manager at /secrets/firebase.json.
# FIREBASE_SERVICE_ACCOUNT_PATH=/secrets/firebase.json

# Comma-separated list of allowed CORS origins. Defaults to localhost dev.
# ALLOWED_ORIGINS=https://meridian.example.com,https://app.meridian.example.com
