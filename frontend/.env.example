# Meridian frontend env vars.
# Copy to `.env.local` and fill in for your environment.

# Backend API base URL. Defaults to "/api" (Vite proxy). Override for production.
VITE_API_URL=/api

# Auth mode. When `true` (default), Firebase is bypassed and a local-only "dev"
# user is signed in automatically — matches the backend's MERIDIAN_DEV_AUTH=true.
# Flip to `false` for production / staging where you want real Firebase Auth.
VITE_DEV_AUTH=true

# Firebase config — required when VITE_DEV_AUTH=false. Get these from the
# Firebase console → Project settings → "Your apps" → Web app config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
